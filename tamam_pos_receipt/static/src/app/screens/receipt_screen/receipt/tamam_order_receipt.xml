<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="tamam_pos_receipt.ReceiptHeader" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//div[span[hasclass('tracking-number')]]" position="replace">
            <div t-if="order.tracking_number and order.config.displayTrackingNumber and !order.config.displayBigTrackingNumber"
                 class="text-center tamam-receipt-number-block">
                <span class="tamam-receipt-number">
                    Receipt no <t t-esc="order.tracking_number"/>
                </span>
            </div>
        </xpath>
    </t>

    <t t-name="tamam_pos_receipt.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('before-footer')]" position="after">
            <div t-if="order.config.till_number" class="tamam-till-number text-center pt-3">
                TILL NUMBER - <t t-esc="order.config.till_number"/>
            </div>
        </xpath>

        <xpath expr="//div[@t-if='order.config.receipt_footer']" position="attributes">
            <attribute name="class">tamam-footer-message pos-receipt-center-align pt-2 text-center</attribute>
        </xpath>

        <xpath expr="//div[hasclass('d-flex') and hasclass('gap-2') and hasclass('pt-3')][.//div[hasclass('pos-config-name')]]" position="replace">
            <div t-if="order.config.name" class="pos-receipt-order-data text-center pt-3 tamam-pos-name">
                <span t-out="order.config.name"/>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('footer-powered-by')]" position="replace"/>
    </t>

    <t t-name="tamam_pos_receipt.RestaurantOrderReceipt" t-inherit="pos_restaurant.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('restaurant-pro-forma-receipt')]" position="attributes">
            <attribute name="class">restaurant-pro-forma-receipt tamam-pro-forma-receipt text-center</attribute>
        </xpath>
    </t>
</templates>
