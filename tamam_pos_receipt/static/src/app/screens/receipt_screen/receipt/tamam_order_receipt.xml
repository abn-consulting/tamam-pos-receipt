<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="tamam_pos_receipt.ReceiptHeader" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//h1[hasclass('tracking-number')]" position="replace">
            <div t-if="props.data.trackingNumber and props.data.bigTrackingNumber"
                 class="text-center tamam-receipt-number-block">
                <span class="tamam-receipt-number">
                    Receipt no <t t-esc="props.data.trackingNumber"/>
                </span>
            </div>
        </xpath>

        <xpath expr="//div[span[hasclass('tracking-number')]]" position="replace">
            <div t-if="props.data.trackingNumber and !props.data.bigTrackingNumber"
                 class="text-center tamam-receipt-number-block">
                <span class="tamam-receipt-number">
                    Receipt no <t t-esc="props.data.trackingNumber"/>
                </span>
            </div>
        </xpath>
    </t>

    <t t-name="tamam_pos_receipt.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//ReceiptHeader" position="after">
            <div t-if="props.data.isBill" class="tamam-pro-forma-receipt text-center">
                Pro forma receipt
            </div>
        </xpath>

        <xpath expr="//div[hasclass('before-footer')]" position="after">
            <div t-if="props.data.till_number" class="tamam-till-number text-center pt-3">
                TILL NUMBER - <t t-esc="props.data.till_number"/>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('pos-receipt-order-data')]/t[@t-if='props.data.isBill']/div[normalize-space()='PRO FORMA']"
               position="replace">
            <t t-if="false"/>
        </xpath>

        <xpath expr="//div[@t-if='props.data.footer']" position="attributes">
            <attribute name="class">tamam-footer-message pos-receipt-center-align pt-2 text-center</attribute>
        </xpath>

        <xpath expr="//div[hasclass('pos-receipt-order-data')][p[normalize-space()='Powered by Odoo']]" position="replace">
            <div t-if="props.data.pos_config_name" class="pos-receipt-order-data text-center pt-3 tamam-pos-name">
                <span t-esc="props.data.pos_config_name"/>
            </div>
        </xpath>
    </t>
</templates>
